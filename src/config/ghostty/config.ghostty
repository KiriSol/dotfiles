theme = Catppuccin Frappe

window-padding-balance = true
window-padding-x = 3
window-padding-y = 3
window-height = 32
window-width = 120

background-opacity = 0.8

bold-color = bright

cursor-style-blink = false

font-size = 13
font-family = JetBrainsMono Nerd Font

copy-on-select = clipboard

mouse-hide-while-typing = true
